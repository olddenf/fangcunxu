<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 垂直线 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#80FFFFFF" />
        </shape>
    </item>
    <item android:left="33.33dp" android:right="33.33dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#80FFFFFF" />
        </shape>
    </item>
    <!-- 水平线 -->
    <item>
        <rotate android:fromDegrees="90">
            <shape android:shape="rectangle">
                <solid android:color="#00000000" />
                <stroke
                    android:width="1dp"
                    android:color="#80FFFFFF" />
            </shape>
        </rotate>
    </item>
    <item android:top="33.33dp" android:bottom="33.33dp">
        <rotate android:fromDegrees="90">
            <shape android:shape="rectangle">
                <solid android:color="#00000000" />
                <stroke
                    android:width="1dp"
                    android:color="#80FFFFFF" />
            </shape>
        </rotate>
    </item>
</layer-list>
